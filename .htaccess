# Warcry CMS V2 security hardening
Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
RewriteEngine On
# Block hidden files/folders like .git, .env, .svn
RewriteRule (^|/)\. - [F]
</IfModule>

<FilesMatch "(^\.env|^\.git|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|webpack\.config\.js|.*\.(bak|backup|old|orig|save|sql|sqlite|log|ini|yml|yaml|md))$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Custom Warcry 404 page
ErrorDocument 404 /warcry/404.php
